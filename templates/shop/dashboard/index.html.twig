{% extends 'shop/base.html.twig' %}

{% block title %}Shop{% endblock %}

{% block breadcrumbs %}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item active">Home</li>
        </ol>
    </nav>
{% endblock %}

{% block body %}

    {# ===== SEARCH ===== #}
    <div class="card shadow-sm p-3 mb-4">
        <form method="get" action="{{ path('app_shop_dashboard') }}">
            <div class="input-group">
                <input
                    type="text"
                    name="q"
                    value="{{ app.request.query.get('q') }}"
                    class="form-control"
                    placeholder="Search products..."
                >
                <button class="btn btn-primary" type="submit">
                    Search
                </button>
            </div>
        </form>
    </div>

    {# ===== PRODUCTS GRID ===== #}
    <div class="row g-4">

        {% if products is not empty %}
            {% for product in products %}
                <div class="col-md-3">
                    <div class="card shadow-sm h-100">

                        {# Optional image #}
                        {% if product.image is defined and product.image %}
                            <img src="{{ asset(product.image) }}" class="card-img-top" alt="{{ product.name }}">
                        {% endif %}

                        <div class="card-body d-flex flex-column">
                            <h2 class="h6">{{ product.name }}</h2>

                            <p class="text-muted small flex-grow-1">
                                {{ product.description|default('No description')|slice(0, 80) }}
                            </p>

                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="fw-bold">
                                    {{ product.price }} €
                                </span>

                                <a href="{{ path('app_shop_product_show', {id: product.id}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="col-12">
                <div class="alert alert-info mb-0">
                    No products found.
                </div>
            </div>
        {% endif %}

    </div>

{% endblock %}
