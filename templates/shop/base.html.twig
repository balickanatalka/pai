<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Shop{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light d-flex flex-column min-vh-100">

{# ===== NAVBAR ===== #}
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
    <div class="container">

        <a class="navbar-brand fw-bold" href="{{ path('app_shop_dashboard') }}">
            🛒 Shop
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#shopNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="shopNavbar">

            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_shop_dashboard') }}">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Products</a>
                </li>
            </ul>

            <div class="d-flex align-items-center">
                {% if app.user %}
                    <span class="me-3 text-muted small">
                        {{ app.user.email }}
                    </span>

                    <a href="{{ path('app_shop_account') }}" class="btn btn-outline-primary btn-sm me-2">
                        Account
                    </a>

                    <a href="{{ path('app_shop_logout') }}" class="btn btn-outline-danger btn-sm">
                        Logout
                    </a>
                {% else %}
                    <a href="{{ path('app_shop_login') }}" class="btn btn-primary btn-sm">
                        Login
                    </a>
                {% endif %}
            </div>

        </div>
    </div>
</nav>

{# ===== MAIN ===== #}
<main class="container py-4 flex-grow-1">

    {% block breadcrumbs %}
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_shop_dashboard') }}">Home</a>
                </li>
            </ol>
        </nav>
    {% endblock %}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} mb-3">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}

</main>

{# ===== FOOTER ===== #}
<footer class="bg-white border-top py-3">
    <div class="container text-center text-muted small">
        &copy; {{ "now"|date("Y") }} Shop
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}{% endblock %}

</body>
</html>
