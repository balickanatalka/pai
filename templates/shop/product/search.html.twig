{% extends 'shop/base.html.twig' %}

{% block title %}Wyszukiwanie produktów{% endblock %}

{% block breadcrumbs %}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="{{ path('app_shop_dashboard') }}">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                Search
            </li>
        </ol>
    </nav>
{% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-body">

            <h1 class="h4 mb-4">Wyszukiwanie produktów</h1>

            <form method="get" action="{{ path('app_shop_product_search') }}" class="mb-4">
                <div class="row g-2">

                    {# SEARCH #}
                    <div class="col-md-4">
                        <input
                            type="text"
                            name="q"
                            value="{{ query|default('') }}"
                            class="form-control"
                            placeholder="Wpisz nazwę produktu..."
                        >
                    </div>

                    {# BRAND #}
                    <div class="col-md-3">
                        <select name="brand" class="form-select">
                            <option value="">Wszystkie marki</option>
                            {% for item in brands %}
                                <option value="{{ item.id }}"
                                    {{ brand is not empty and brand == item.id ? 'selected' }}>
                                    {{ item.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    {# CATEGORY #}
                    <div class="col-md-3">
                        <select name="category" class="form-select">
                            <option value="">Wszystkie kategorie</option>
                            {% for item in categories %}
                                <option value="{{ item.id }}"
                                    {{ category is not empty and category == item.id ? 'selected' }}>
                                    {{ item.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    {# BUTTON #}
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" type="submit">
                            Szukaj
                        </button>
                    </div>

                </div>
            </form>

            {% if query %}
                <p class="text-muted">
                    Wyniki dla: <strong>{{ query }}</strong>
                </p>
            {% endif %}

            {% if products is empty %}
                <div class="alert alert-warning mb-0">
                    Brak produktów do wyświetlenia.
                </div>
            {% else %}
                <div class="row g-3">
                    {% for product in products %}
                        <div class="col-md-4">
                            <div class="card h-100">
                                <div class="card-body">

                                    <h2 class="h6 card-title">
                                        {{ product.name }}
                                    </h2>

                                    {% if product.model %}
                                        <p class="text-muted small mb-1">
                                            Model: {{ product.model }}
                                        </p>
                                    {% endif %}

                                    {% if product.brand %}
                                        <p class="text-muted small mb-1">
                                            Marka: {{ product.brand.name }}
                                        </p>
                                    {% endif %}

                                    {% if product.category %}
                                        <p class="text-muted small mb-2">
                                            Kategoria: {{ product.category.name }}
                                        </p>
                                    {% endif %}

                                    <p class="fw-bold mb-0">
                                        {{ product.price }} zł
                                    </p>

                                    <div class="mt-2">
                                        <a href="{{ path('app_shop_product_show', {id: product.id}) }}"
                                           class="btn btn-sm btn-outline-primary">
                                            Zobacz
                                        </a>
                                    </div>

                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </div>
{% endblock %}
