{% extends 'shop/base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block breadcrumbs %}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="{{ path('app_shop_dashboard') }}">Home</a>
            </li>
            <li class="breadcrumb-item active">
                {{ product.name }}
            </li>
        </ol>
    </nav>
{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">
        <div class="row g-4">

            <div class="col-md-8">
                <h1 class="h3 mb-3">{{ product.name }}</h1>

                <table class="table table-bordered align-middle">
                    <tbody>
                    <tr>
                        <th>Price</th>
                        <td>
                            <strong>{{ product.price }} €</strong>
                        </td>
                    </tr>

                    <tr>
                        <th>Stock</th>
                        <td>
                            {% if product.stockQuantity > 0 %}
                                <span class="badge bg-success">
                                    In stock: {{ product.stockQuantity }}
                                </span>
                            {% else %}
                                <span class="badge bg-danger">
                                    Out of stock
                                </span>
                            {% endif %}
                        </td>
                    </tr>

                    <tr>
                        <th>Model</th>
                        <td>{{ product.model ?: '-' }}</td>
                    </tr>

                    <tr>
                        <th>Brand name</th>
                        <td>{{ product.brandName ?: '-' }}</td>
                    </tr>

                    <tr>
                        <th>Category</th>
                        <td>{{ product.category ? product.category.name : '-' }}</td>
                    </tr>

                    <tr>
                        <th>Brand</th>
                        <td>{{ product.brand ? product.brand.name : '-' }}</td>
                    </tr>

                    <tr>
                        <th>Manufacturer</th>
                        <td>{{ product.manufacturer ? product.manufacturer.name : '-' }}</td>
                    </tr>
                    </tbody>
                </table>

                <a href="{{ path('app_shop_dashboard') }}" class="btn btn-secondary">
                    Back to shop
                </a>
            </div>

            <div class="col-md-4">
                <div class="border rounded p-3 bg-light">
                    <h2 class="h5 mb-3">Purchase</h2>

                    <p class="text-muted">
                        Product details and purchase options.
                    </p>

                    <button class="btn btn-primary w-100" disabled>
                        Add to cart
                    </button>
                </div>
            </div>

        </div>
    </div>
{% endblock %}
