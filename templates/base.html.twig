<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}PAI{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {% endblock %}
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">

        <a class="navbar-brand" href="{{ path('app_shop_dashboard') }}">
            PAI
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#shopNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="shopNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_shop_dashboard') }}">
                        Home
                    </a>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        Brands
                    </a>

                    <ul class="dropdown-menu">
                        {% for brand in shop_brands() %}
                            <li>
                                <a class="dropdown-item"
                                   href="{{ path('app_shop_product_search', {brand: brand.id}) }}">
                                    {{ brand.name }}
                                </a>
                            </li>
                        {% else %}
                            <li>
                                <span class="dropdown-item text-muted">
                                    No brands
                                </span>
                            </li>
                        {% endfor %}
                    </ul>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        Categories
                    </a>

                    <ul class="dropdown-menu">
                        {% for category in shop_categories() %}
                            <li>
                                <a class="dropdown-item"
                                   href="{{ path('app_shop_product_search', {category: category.id}) }}">
                                    {{ category.name }}
                                </a>
                            </li>
                        {% else %}
                            <li>
                                <span class="dropdown-item text-muted">
                                    No categories
                                </span>
                            </li>
                        {% endfor %}
                    </ul>
                </li>

            </ul>

            <div class="d-flex align-items-center">
                {% if app.user %}
                    <span class="text-light small me-3">
                        {{ app.user.email }}
                    </span>

                    <a href="{{ path('app_shop_account_index') }}"
                       class="btn btn-outline-light btn-sm me-2">
                        Account
                    </a>

                    <a href="{{ path('app_shop_logout') }}"
                       class="btn btn-outline-danger btn-sm">
                        Logout
                    </a>
                {% else %}
                    <a href="{{ path('app_shop_login') }}"
                       class="btn btn-outline-light btn-sm me-2">
                        Login
                    </a>

                    <a href="{{ path('app_shop_register') }}"
                       class="btn btn-primary btn-sm">
                        Register
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>

<main class="container py-4">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer class="text-center text-muted py-4">
    {% block footer %}
        © 2026 PAI App
    {% endblock %}
</footer>

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}

</body>
</html>
