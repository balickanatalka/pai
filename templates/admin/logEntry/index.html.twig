{% extends 'admin/base.html.twig' %}

{% block title %}Change logs{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">
                Change logs
            </h1>
        </div>

        <form method="get" class="row g-3 mb-4">
            <div class="col-md-4">
                <label for="entity" class="form-label">
                    Entity
                </label>

                <select name="entity" id="entity" class="form-select">
                    <option value="">All entities</option>

                    {% for value, label in entities %}
                        <option value="{{ value }}" {% if selectedEntity == value %}selected{% endif %}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-md-8 d-flex align-items-end gap-2">
                <button class="btn btn-primary">
                    Filter
                </button>

                <a href="{{ path('app_log_index') }}" class="btn btn-outline-secondary">
                    Reset
                </a>
            </div>
        </form>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Entity</th>
                <th>Object ID</th>
                <th>Action</th>
                <th>Version</th>
                <th>Date</th>
                <th>Username</th>
                <th>Changes</th>
            </tr>
            </thead>

            <tbody>
            {% for log in logs %}
                <tr>
                    <td>{{ log.id }}</td>

                    <td>
                        {{ log.objectClass|split('\\')|last }}
                    </td>

                    <td>
                        {{ log.objectId }}
                    </td>

                    <td>
                        <span class="badge bg-secondary">
                            {{ log.action }}
                        </span>
                    </td>

                    <td>
                        {{ log.version }}
                    </td>

                    <td>
                        {{ log.loggedAt ? log.loggedAt|date('Y-m-d H:i:s') : '-' }}
                    </td>

                    <td>
                        {{ log.username ?: '-' }}
                    </td>

                    <td>
                        <pre class="mb-0 small">{{ log.data|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="text-center text-muted">
                        No logs found.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>
{% endblock %}
