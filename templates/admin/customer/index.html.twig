{% extends 'admin/base.html.twig' %}

{% block title %}Customers{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between mb-4">
            <h1>Customers</h1>

            <a href="{{ path('app_customer_new') }}" class="btn btn-success">
                + Add customer
            </a>
        </div>

        <table class="table table-striped">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>First name</th>
                <th>Last name</th>
                <th>Email</th>
                <th>Phone</th>
                <th></th>
            </tr>
            </thead>

            <tbody>
            {% for customer in customers %}
                <tr>
                    <td>{{ customer.id }}</td>
                    <td>{{ customer.firstName }}</td>
                    <td>{{ customer.lastName }}</td>
                    <td>{{ customer.email }}</td>
                    <td>{{ customer.phoneNumber }}</td>

                    <td class="text-end">
                        <a href="{{ path('app_customer_show', {id: customer.id}) }}" class="btn btn-sm btn-info">Show</a>
                        <a href="{{ path('app_customer_edit', {id: customer.id}) }}" class="btn btn-sm btn-warning">Edit</a>

                        <form method="post"
                              action="{{ path('app_customer_delete', {id: customer.id}) }}"
                              style="display:inline-block"
                              onsubmit="return confirm('Delete?');">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete_customer_' ~ customer.id) }}">
                            <button class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center">No data</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>
{% endblock %}
