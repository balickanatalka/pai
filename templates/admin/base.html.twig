<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Admin{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# Bootstrap CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>

<body class="bg-light">

{# ===== TOP NAVBAR ===== #}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand" href="{{ path('app_admin_dashboard_index') }}">
            Admin
        </a>

        <div class="d-flex align-items-center ms-auto">
            <div class="text-white me-3">
                {{ app.user.email }}
            </div>

            <a href="{{ path('app_admin_logout') }}" class="btn btn-outline-light btn-sm">
                Logout
            </a>
        </div>
    </div>
</nav>

<div class="container-fluid">
    <div class="row min-vh-100">

        {# ===== SIDEBAR ===== #}
        <aside class="col-md-3 col-lg-2 bg-white border-end p-0">
            <div class="p-3 border-bottom">
                <strong>Admin menu</strong>
            </div>

            <div class="list-group list-group-flush">

                <a href="{{ path('app_admin_dashboard_index') }}"
                   class="list-group-item list-group-item-action">
                    Dashboard
                </a>

                <a href="{{ path('app_permission_index') }}"
                   class="list-group-item list-group-item-action">
                    Permissions
                </a>

                <a href="{{ path('app_role_index') }}"
                   class="list-group-item list-group-item-action">
                    Roles
                </a>

                <a href="{{ path('app_customer_index') }}"
                   class="list-group-item list-group-item-action">
                    Customers
                </a>

                <a href="{{ path('app_employee_index') }}"
                   class="list-group-item list-group-item-action">
                    Employees
                </a>

                {# NEW: PRODUCTS #}
                <a href="{{ path('app_product_index') }}"
                   class="list-group-item list-group-item-action">
                    Products
                </a>

                <a href="{{ path('app_user_index') }}"
                   class="list-group-item list-group-item-action">
                    Users
                </a>

            </div>
        </aside>

        {# ===== MAIN CONTENT ===== #}
        <main class="col-md-9 col-lg-10 p-0">

            {# Breadcrumbs #}
            <div class="bg-white border-bottom">
                <div class="container-fluid py-2">
                    {% block breadcrumbs %}
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_admin_dashboard_index') }}">Dashboard</a>
                                </li>
                            </ol>
                        </nav>
                    {% endblock %}
                </div>
            </div>

            {# Flash messages #}
            <div class="container-fluid mt-3">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} alert-dismissible fade show">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {# Page content #}
            <div class="container-fluid py-4">
                {% block body %}{% endblock %}
            </div>

        </main>
    </div>
</div>

{# Bootstrap JS #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}{% endblock %}
</body>
</html>
