{% extends 'base.html.twig' %}

{% block title %}Permissions{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Lista uprawnień</h1>

            <a href="{{ path('app_permission_new') }}" class="btn btn-success">
                + Dodaj permission
            </a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Code</th>
                <th>Name</th>
                <th>Description</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>

            <tbody>
            {% for permission in permissions %}
                <tr>
                    <td>{{ permission.id }}</td>

                    <td>
                        <span class="badge bg-secondary">
                            {{ permission.code }}
                        </span>
                    </td>

                    <td>{{ permission.name }}</td>

                    <td>
                        {{ permission.description ?: '-' }}
                    </td>

                    <td class="text-end">

                        <a href="{{ path('app_permission_show', {id: permission.id}) }}"
                           class="btn btn-sm btn-info">
                            Show
                        </a>

                        <a href="{{ path('app_permission_edit', {id: permission.id}) }}"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <form method="post"
                              action="{{ path('app_permission_delete', {id: permission.id}) }}"
                              style="display:inline-block"
                              onsubmit="return confirm('Czy na pewno usunąć?');">

                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token('delete_permission_' ~ permission.id) }}">

                            <button class="btn btn-sm btn-danger">
                                Delete
                            </button>
                        </form>

                    </td>
                </tr>

            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted">
                        Brak uprawnień w bazie
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>
{% endblock %}
