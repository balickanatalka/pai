{% extends 'admin/base.html.twig' %}

{% block title %}Permissions{% endblock %}

{% block breadcrumbs %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="{{ path('app_admin_dashboard_index') }}">Dashboard</a>
            </li>
            <li class="breadcrumb-item active">Permissions</li>
        </ol>
    </nav>
{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Permission list</h1>

            <a href="{{ path('app_permission_new') }}" class="btn btn-success">
                Add permission
            </a>
        </div>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Code</th>
                <th>Name</th>
                <th>Description</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>

            <tbody>
            {% for permission in permissions %}
                <tr>
                    <td>{{ permission.id }}</td>

                    <td>
                            <span class="badge bg-secondary">
                                {{ permission.code }}
                            </span>
                    </td>

                    <td>{{ permission.name }}</td>

                    <td>
                        {{ permission.description ?: '-' }}
                    </td>

                    <td class="text-end">

                        <a href="{{ path('app_permission_show', {id: permission.id}) }}"
                           class="btn btn-sm btn-outline-info">
                            Show
                        </a>

                        <a href="{{ path('app_permission_edit', {id: permission.id}) }}"
                           class="btn btn-sm btn-outline-warning">
                            Edit
                        </a>

                        <form method="post"
                              action="{{ path('app_permission_delete', {id: permission.id}) }}"
                              class="d-inline-block"
                              onsubmit="return confirm('Are you sure to delete?');">

                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token('delete_permission_' ~ permission.id) }}">

                            <button class="btn btn-sm btn-outline-danger">
                                Delete
                            </button>
                        </form>

                    </td>
                </tr>

            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted">
                        No permissions in the database.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>
{% endblock %}
