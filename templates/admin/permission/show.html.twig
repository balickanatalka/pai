{% extends 'base.html.twig' %}

{% block title %}Permission details{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">
        <h1 class="mb-4">Permission details</h1>

        <table class="table">
            <tbody>
            <tr>
                <th>ID</th>
                <td>{{ permission.id }}</td>
            </tr>
            <tr>
                <th>Code</th>
                <td>{{ permission.code }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ permission.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ permission.description }}</td>
            </tr>
            </tbody>
        </table>

        <a href="{{ path('app_permission_index') }}" class="btn btn-secondary">Back to list</a>
        <a href="{{ path('app_permission_edit', {id: permission.id}) }}" class="btn btn-warning">Edit</a>
    </div>
{% endblock %}
