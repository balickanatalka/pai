{% extends 'admin/base.html.twig' %}

{% block title %}Permission details{% endblock %}

{% block breadcrumbs %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="{{ path('app_admin_dashboard_index') }}">Dashboard</a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_permission_index') }}">Permissions</a>
            </li>
            <li class="breadcrumb-item active">Details</li>
        </ol>
    </nav>
{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Permission details</h1>

            <div>
                <a href="{{ path('app_permission_edit', {id: permission.id}) }}"
                   class="btn btn-outline-warning">
                    Edit
                </a>
            </div>
        </div>

        <table class="table table-bordered align-middle">
            <tbody>
            <tr>
                <th style="width: 150px;">ID</th>
                <td>{{ permission.id }}</td>
            </tr>
            <tr>
                <th>Code</th>
                <td>
                        <span class="badge bg-secondary">
                            {{ permission.code }}
                        </span>
                </td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ permission.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ permission.description ?: '-' }}</td>
            </tr>
            </tbody>
        </table>

        <div class="mt-3">
            <a href="{{ path('app_permission_index') }}" class="btn btn-secondary">
                Back to list
            </a>
        </div>

    </div>
{% endblock %}
