{% extends 'admin/base.html.twig' %}

{% block title %}Brands{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Brands</h1>

        <a href="{{ path('app_admin_brand_new') }}" class="btn btn-primary">
            Add brand
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            {% if brands is empty %}
                <div class="alert alert-info mb-0">
                    No brands found.
                </div>
            {% else %}

                <table class="table table-striped align-middle mb-0">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Code</th>
                        <th>Active</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    {% for brand in brands %}
                        <tr>
                            <td>{{ brand.id }}</td>
                            <td>{{ brand.name }}</td>
                            <td>{{ brand.code }}</td>

                            <td>
                                {% if brand.isActive %}
                                    <span class="badge bg-success">Yes</span>
                                {% else %}
                                    <span class="badge bg-secondary">No</span>
                                {% endif %}
                            </td>

                            <td class="text-end">
                                <a href="{{ path('app_admin_brand_edit', {id: brand.id}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                <form method="post"
                                      action="{{ path('app_admin_brand_delete', {id: brand.id}) }}"
                                      class="d-inline"
                                      onsubmit="return confirm('Delete this brand?');">

                                    <input type="hidden"
                                           name="_token"
                                           value="{{ csrf_token('delete_brand_' ~ brand.id) }}">

                                    <button class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>

            {% endif %}

        </div>
    </div>

{% endblock %}
