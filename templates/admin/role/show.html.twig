{% extends 'base.html.twig' %}

{% block title %}Role details{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">
        <h1 class="mb-4">Szczegóły roli</h1>

        <table class="table table-bordered">
            <tbody>
            <tr>
                <th>ID</th>
                <td>{{ role.id }}</td>
            </tr>
            <tr>
                <th>Code</th>
                <td>
                    <span class="badge bg-primary">{{ role.code }}</span>
                </td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ role.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ role.description ?: '-' }}</td>
            </tr>
            <tr>
                <th>System</th>
                <td>
                    {% if role.isSystem %}
                        <span class="badge bg-danger">SYSTEM</span>
                    {% else %}
                        <span class="badge bg-secondary">CUSTOM</span>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Permissions</th>
                <td>
                    {% if role.permissions|length > 0 %}
                        <ul class="mb-0">
                            {% for permission in role.permissions %}
                                <li>
                                    <strong>{{ permission.code }}</strong>
                                    {% if permission.name %}
                                        — {{ permission.name }}
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <span class="text-muted">No permissions assigned</span>
                    {% endif %}
                </td>
            </tr>
            </tbody>
        </table>

        <div class="d-flex gap-2">
            <a href="{{ path('app_role_index') }}" class="btn btn-secondary">
                Back to list
            </a>

            <a href="{{ path('app_role_edit', {id: role.id}) }}" class="btn btn-warning">
                Edit
            </a>
        </div>
    </div>
{% endblock %}
