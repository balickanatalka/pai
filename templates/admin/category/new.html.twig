{% extends 'admin/base.html.twig' %}

{% block title %}Add category{% endblock %}

{% block body %}

    <h1 class="h3 mb-4">
        Add category
    </h1>

    <div class="card shadow-sm">
        <div class="card-body">

            {{ form_start(form) }}

            {{ form_widget(form) }}

            <button class="btn btn-primary">
                Save
            </button>

            <a href="{{ path('app_admin_category_index') }}"
               class="btn btn-outline-secondary">
                Back
            </a>

            {{ form_end(form) }}

        </div>
    </div>

{% endblock %}
