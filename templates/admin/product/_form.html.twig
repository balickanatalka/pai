{{ form_start(form) }}

<div class="row g-3">

    <div class="col-md-6">
        {{ form_label(form.name) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.name) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.price) }}
        {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.price) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.stockQuantity) }}
        {{ form_widget(form.stockQuantity, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.stockQuantity) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.model) }}
        {{ form_widget(form.model, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.model) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.brandName) }}
        {{ form_widget(form.brandName, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.brandName) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.category) }}
        {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.category) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.brand) }}
        {{ form_widget(form.brand, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.brand) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.manufacturer) }}
        {{ form_widget(form.manufacturer, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.manufacturer) }}
    </div>

</div>

<button class="btn btn-primary mt-4">
    {{ form.vars.value.id ? 'Update' : 'Create' }}
</button>

{{ form_end(form) }}
