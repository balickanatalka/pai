{% extends 'admin/base.html.twig' %}

{% block title %}Product details{% endblock %}

{% block body %}
    <div class="card shadow-sm p-4">
        <h1 class="mb-4">Product details</h1>

        <table class="table table-bordered">
            <tbody>

            <tr>
                <th>ID</th>
                <td>{{ product.id }}</td>
            </tr>

            <tr>
                <th>Name</th>
                <td>{{ product.name }}</td>
            </tr>

            <tr>
                <th>Price</th>
                <td><strong>{{ product.price }} €</strong></td>
            </tr>

            <tr>
                <th>Stock</th>
                <td>{{ product.stockQuantity }}</td>
            </tr>

            <tr>
                <th>Model</th>
                <td>{{ product.model ?: '-' }}</td>
            </tr>

            <tr>
                <th>Brand name</th>
                <td>{{ product.brandName ?: '-' }}</td>
            </tr>

            <tr>
                <th>Category</th>
                <td>{{ product.category ? product.category.name : '-' }}</td>
            </tr>

            <tr>
                <th>Brand</th>
                <td>{{ product.brand ? product.brand.name : '-' }}</td>
            </tr>

            <tr>
                <th>Manufacturer</th>
                <td>{{ product.manufacturer ? product.manufacturer.name : '-' }}</td>
            </tr>

            </tbody>
        </table>

        <div class="d-flex gap-2">
            <a href="{{ path('app_product_index') }}" class="btn btn-secondary">
                Back to list
            </a>

            <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-warning">
                Edit
            </a>

            <form method="post"
                  action="{{ path('app_product_delete', {id: product.id}) }}"
                  onsubmit="return confirm('Are you sure you want to delete this product?');">

                <input type="hidden"
                       name="_token"
                       value="{{ csrf_token('delete_product_' ~ product.id) }}">

                <button class="btn btn-danger">
                    Delete
                </button>
            </form>
        </div>
    </div>
{% endblock %}
